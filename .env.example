# MongoDB Atlas/local connection string (optional — app works without it)
MONGODB_URI="mongodb+srv://USER:PASSWORD@cluster.mongodb.net/slanguary?retryWrites=true&w=majority"

# Public-facing URL for sitemap, structured data, canonical links
# Vercel sets VERCEL_URL automatically; only needed for local dev or custom domain
NEXT_PUBLIC_SITE_URL="https://slanguage.vercel.app"

# Admin login password for /admin/submissions
ADMIN_PASSWORD="change-me"

# Any long random string used to sign the admin cookie
ADMIN_COOKIE_SECRET="replace-with-a-long-random-secret"
